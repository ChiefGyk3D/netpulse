# NetPulse Configuration
# Copy this file to .env and modify as needed
#
# For Docker: Used by docker-compose.yml
# For Local:  setup.sh generates /etc/netpulse/netpulse.env from these values

# InfluxDB Version: "1" for 1.x (username/password) or "2" for 2.x (token-based)
# Docker Compose uses InfluxDB 2.x by default
INFLUXDB_VERSION=2

# InfluxDB Connection
INFLUXDB_URL=http://localhost:8086

# ═══════════════════════════════════════════════════════════════
# InfluxDB 2.x Settings (token-based authentication)
# Used when INFLUXDB_VERSION=2
# ═══════════════════════════════════════════════════════════════
INFLUXDB_TOKEN=netpulse-token-change-me-to-something-secure
INFLUXDB_ORG=netpulse
INFLUXDB_BUCKET=netpulse

# Initial setup credentials (Docker only - for web UI access)
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=netpulse123

# ═══════════════════════════════════════════════════════════════
# InfluxDB 1.x Settings (username/password authentication)
# Used when INFLUXDB_VERSION=1
# ═══════════════════════════════════════════════════════════════
# INFLUXDB_USERNAME=admin
# INFLUXDB_PASSWORD=netpulse123
# INFLUXDB_DATABASE=netpulse

# ═══════════════════════════════════════════════════════════════
# Grafana Settings (Docker only)
# ═══════════════════════════════════════════════════════════════
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ═══════════════════════════════════════════════════════════════
# Simplified Runner (Ookla) Settings
# ═══════════════════════════════════════════════════════════════
# Interval in seconds between speedtests (default: 1800 = 30 minutes)
# For systemd timer: edit /etc/systemd/system/netpulse.timer instead
SPEEDTEST_INTERVAL=1800

# Cron expression for scheduling (overrides SPEEDTEST_INTERVAL when set).
# Examples:
#   "0 */6 * * *"        — every 6 hours
#   "0 3,9,15,21 * * *"  — at 03:00, 09:00, 15:00, 21:00
#   "0 */2 * * *"        — every 2 hours
# Leave empty to use SPEEDTEST_INTERVAL.
SPEEDTEST_CRON=

# ═══════════════════════════════════════════════════════════════
# Enhanced Runner (Cloudflare) Settings
# Activate with: docker-compose --profile enhanced up
# ═══════════════════════════════════════════════════════════════
# Interval in seconds between Cloudflare speed tests (default: 21600 = 6 hours)
CF_SPEEDTEST_INTERVAL=21600

# Cron expression for the Cloudflare runner (overrides CF_SPEEDTEST_INTERVAL).
# Example for 03:00, 09:00, 15:00, 21:00 daily:
#   CF_SPEEDTEST_CRON=0 3,9,15,21 * * *
CF_SPEEDTEST_CRON=

# Number of latency samples used for Cloudflare latency/jitter measurement
CF_LATENCY_SAMPLES=20

# ═══════════════════════════════════════════════════════════════
# Privacy Settings
# ═══════════════════════════════════════════════════════════════
# Set to "true" to mask your external IP address in InfluxDB and Grafana.
# When enabled, the IP is stored as "hidden" instead of the real address.
# Useful when displaying dashboards publicly (e.g., on a stream).
HIDE_EXTERNAL_IP=false

# ═══════════════════════════════════════════════════════════════
# General Settings
# ═══════════════════════════════════════════════════════════════
# State file for ISP change tracking (auto-configured by setup.sh)
# Docker: /data/state.json (in volume)
# Local:  /var/lib/netpulse/state.json
# NETPULSE_STATE_FILE=/var/lib/netpulse/state.json

# Timezone
TZ=America/New_York
